class Solution {
public:
    int lengthOfLastWord(string s) {
        int count=0;
    int n = s.size() - 1, len = 0;
    for (int i = s.size() - 1; i >= 0; i--) {
            if (s[i] == ' ' && count == 0) continue;

            if (s[i] != ' ') count++;
            else break;
        }

        return count;
    }
};
