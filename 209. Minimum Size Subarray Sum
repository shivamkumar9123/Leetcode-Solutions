class Solution {
public:
    int minSubArrayLen(int target, vector<int>& nums) {
    int n=nums.size();
    int sum=0;
    int left=0;  
    int minLen=INT_MAX;
    for(int right=0;right<n; right++){
        sum+=nums[right];

        while(sum >=target){
        int windowSize = right-left+1;
        minLen=min(minLen,windowSize);
        sum -=nums[left];
        left++;

        }    
    }
    // shrink window while sum is enough
    
    
    if(minLen == INT_MAX)
        return 0;

    return minLen;
    }
};
