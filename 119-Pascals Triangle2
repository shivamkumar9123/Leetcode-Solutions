class Solution {
public:
    int NcR(int n, int r) {
        long long res = 1;

        for (int i = 0; i < r; i++) {
            res = res * (n - i);
            res = res / (i + 1);
        }

        return res;
    }

    vector<int> getRow(int rowIndex) {
        vector<int> ans;

        for (int r = 0; r <= rowIndex; r++) {
            ans.push_back(NcR(rowIndex, r));
        }

        return ans;
    }
};
