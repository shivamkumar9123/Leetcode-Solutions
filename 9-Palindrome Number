class Solution {
public:
    bool isPalindrome(int x) {
        if(x<0)return false;
        int original=x;
        long long reversed=0;
        int  remainder;
        while(x>0){
         remainder=x%10;
            reversed=reversed*10 + remainder;
        x=x/10;
        }
        return original==reversed;
    }
};
