class Solution {
public:
    vector<int> plusOne(vector<int>& digits) {
       int carry=1;
       int n=digits.size();
       for(int i=0;i<n;i++){
        int nums=digits[i]+carry;
        digits[i]=nums%10;
        carry=nums/10;
       }
       if(carry>0){
        digits.push_back(0);
        n=digits.size();
        for(int i=0;i<n-1;i++){
            digits[i]=digits[i-1];
        }
        digits[0]=carry;
       }
       return digits;
        }
};
