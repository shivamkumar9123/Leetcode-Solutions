class Solution {
public:
    int majorityElement(vector<int>& nums) {
        int element=0;
        int count=0;
        for(int i=0;i<nums.size();i++){
            if(count==0){   // when count is zero 
                            // then previous candidate cancel
                            // then select new candidate
                element=nums[i];
            }
            //	Same → increase count
	          //	Different → decrease count

            if(element==nums[i]){
                count++;
            }
            else{
                count--;
            }
        }
            return element;
    }
};
